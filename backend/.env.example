# =====================
# Application
# =====================
APP_NAME=FIFA Scoring System
APP_ENV=development
DEBUG=true

# =====================
# API
# =====================
API_PREFIX=/api/v1
API_VERSION=v1
HOST=0.0.0.0
PORT=8000

# =====================
# PostgreSQL Database
# =====================
DATABASE_URL=postgresql://fifa_user:change_me@postgres:5432/fifa_scoring_db
POSTGRES_DB=fifa_scoring_db
POSTGRES_USER=fifa_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_ECHO_SQL=false

# =====================
# Security Placeholder
# =====================
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
